{
  "$schema": "https://stripe.com/stripe-app.schema.json",
  "id": "com.saasradar.connect",
  "name": "SaaS Radar",
  "version": "0.0.3",
  "icon": "./icon_32.png",
  "extensions": null,
  "permissions": [
    {
      "permission": "subscription_read",
      "purpose": "Compter les abonnements actifs et le churn."
    },
    {
      "permission": "customer_read",
      "purpose": "Métriques clients et analytics."
    },
    {
      "permission": "invoice_read",
      "purpose": "Paiements échoués et récupérés (stream revenu)."
    },
    {
      "permission": "charge_read",
      "purpose": "Lecture des charges pour le suivi revenu."
    }
  ],
  "allowed_redirect_uris": [
    "https://saa-s-radar.vercel.app/api/connectors/stripe/callback"
  ],
  "distribution_type": "private",
  "stripe_api_access_type": "oauth",
  "sandbox_install_compatible": true
}