# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role : écriture serveur (sourcing, seed). Ne jamais exposer côté client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Authentification (Supabase Auth : email + mot de passe) ───────────────────
# Aucune clé supplémentaire requise côté app : on réutilise SUPABASE_URL et SUPABASE_ANON_KEY.
#
# Dashboard Supabase (Authentication > Providers > Email) :
#   - Activer « Email » avec mot de passe (désactiver « Confirm email » si comptes internes).
#   - Désactiver Magic Link si vous n'en avez plus besoin.
#
# Créer / réinitialiser un mot de passe (local, service role requis) :
#   tsx --env-file=.env.local scripts/set-auth-passwords.ts email:motdepasse

# ── Stripe (abonnements Builder/Pro, Checkout heberge + webhook) ─────────────
# Cles API (mode test en dev : sk_test_..., whsec_... fourni par `stripe listen`).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Builder 19€/mois & 180€/an, Pro 39€/mois & 372€/an (TTC, sans Stripe Tax au MVP).
STRIPE_PRICE_BUILDER_MONTHLY=
STRIPE_PRICE_BUILDER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
# URL absolue de l'app (auth callback, success/cancel/return Stripe).
# Prod : https://thebuildroad.com — laisser vide en local.
NEXT_PUBLIC_SITE_URL=

# Phase produit : discovery (GTM public) | full (cockpit + checkout).
# Production thebuildroad.com : discovery. Preview dev-alex : full.
NEXT_PUBLIC_PRODUCT_PHASE=discovery

# ── Sourcing IA (OpenRouter) ─────────────────────────────────────────────────
# Obligatoire pour `npm run sourcing`.
OPENROUTER_API_KEY=
# Mettre 1 pour activer les logs verbeux du pipeline (discover/openrouter/extract).
SOURCING_DEBUG=0
# Score plancher (scores.opportunity, 0-100) sous lequel une fiche est rejetée
# avant upsert. Laisser vide ou 0 pour désactiver le garde-fou qualité.
SOURCING_MIN_SCORE=
# Webhook Slack/email quand notify_on_pending est actif (POST JSON).
SOURCING_NOTIFY_WEBHOOK_URL=

# ── Revalidation prod après sourcing ─────────────────────────────────────────
# URL absolue de l'app déployée exposant POST /api/revalidate (ex. https://saasradar.fr).
# Laisser vide en local : l'appel de revalidation devient un no-op.
SOURCING_REVALIDATE_URL=
# Secret partagé entre le script de sourcing et la route /api/revalidate.
REVALIDATE_SECRET=

# ── Admin sourcing (déclenchement protégé /api/admin/sourcing) ────────────────
# Secret machine pour CI/GitHub Actions et exécution sourcing en arrière-plan
# (header x-admin-secret → /api/admin/sourcing/process-queue).
# En local : définir aussi NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_SOURCING_SECRET=

# ── Admin plateforme (phase B) ────────────────────────────────────────────────
# Sous-domaine admin isolé (ex. https://admin.saasradar.fr)
NEXT_PUBLIC_ADMIN_URL=
# Mettre 1 quand les passkeys WebAuthn sont activés dans Supabase Auth
NEXT_PUBLIC_ADMIN_PASSKEYS=0

# ── Scripts utilitaires ──────────────────────────────────────────────────────
# Mettre 1 pour autoriser le seed legacy des 12 mocks (`npm run seed`).
SEED_CONFIRM=
# Nombre de leads ciblés par le test isolé étape A (`npm run sourcing:test-a`).
TEST_COUNT=10

# ── Build cockpit — GitHub App (suivi repo) ───────────────────────────────────
# Créer une GitHub App avec permissions lecture : contents, metadata, actions,
# issues, pull requests. Callback URL : https://<domaine>/api/connectors/github/callback
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
# Tests manuels connecteur (optionnel, hors CI) :
# GITHUB_CONNECTOR_TEST_INSTALLATION_ID=
# GITHUB_CONNECTOR_TEST_REPO=owner/repo

# ── Build cockpit — Vercel OAuth (déploiements) ─────────────────────────────
# Créer une Integration Vercel (scopes : user project deployment team billing)
# Redirect auto-dérivé : {NEXT_PUBLIC_APP_URL}/api/connectors/vercel/callback
# VERCEL_REDIRECT_URI= optionnel (override staging / preview)
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
# VERCEL_REDIRECT_URI=
# VERCEL_CONNECTOR_TEST_ACCESS_TOKEN=
# VERCEL_CONNECTOR_TEST_TEAM_ID=
# VERCEL_CONNECTOR_TEST_PROJECT_ID=

# ── Connecteur Sentry cockpit (monitoring erreurs — OAuth Public Integration) ─
# Sentry → Settings → Developer Settings → Create Public Integration
# Permissions : org:read, project:read, event:read, project:releases
# Redirect URI : https://<domaine>/api/connectors/sentry/callback
# Webhook URL    : https://<domaine>/api/connectors/sentry/webhook
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=
SENTRY_REDIRECT_URI=
SENTRY_APP_SLUG=
# SENTRY_API_HOST=https://sentry.io
# SENTRY_WEBHOOK_SECRET=   # défaut : SENTRY_CLIENT_SECRET
# SENTRY_CONNECTOR_TEST_INSTALLATION_ID=
# SENTRY_CONNECTOR_TEST_ACCESS_TOKEN=
# SENTRY_CONNECTOR_TEST_ORG_SLUG=
# SENTRY_CONNECTOR_TEST_PROJECT_ID=

# ── Connecteur Stripe utilisateurs (cockpit — clé restreinte) ─────────────────
# Aucune variable serveur requise : l'utilisateur colle sa clé rk_test_… / rk_live_…
# dans le cockpit. Seul le chiffrement des credentials est nécessaire côté serveur
# (voir CREDENTIALS_ENCRYPTION_KEY ci-dessous).
# Clé restreinte sandbox pour tests CI (scripts/stripe-connector.test.ts) :
# STRIPE_CONNECTOR_TEST_KEY=rk_test_...

# ── Connecteur Google Ads (cockpit — OAuth) ───────────────────────────────────
# Cloud Console : activer Google Ads API, créer OAuth Web, consent screen.
# Redirect URI : https://<domaine>/api/connectors/google-ads/callback
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REDIRECT_URI=
# Developer token (API Center du compte Google Ads manager) — niveau plateforme
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optionnel : compte manager MCC par défaut (login-customer-id)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Refresh token sandbox pour tests CI (scripts/google-ads-connector.test.ts) :
# GOOGLE_ADS_CONNECTOR_TEST_REFRESH_TOKEN=
# GOOGLE_ADS_CONNECTOR_TEST_CUSTOMER_ID=

# ── Connecteur Google Analytics (cockpit — OAuth GA4) ─────────────────────────
# Cloud Console : activer Google Analytics Data API + Admin API, OAuth Web.
# Redirect URI : https://<domaine>/api/connectors/google-analytics/callback
# Scope : https://www.googleapis.com/auth/analytics.readonly
GOOGLE_ANALYTICS_CLIENT_ID=
GOOGLE_ANALYTICS_CLIENT_SECRET=
GOOGLE_ANALYTICS_REDIRECT_URI=
# GOOGLE_ANALYTICS_CONNECTOR_TEST_REFRESH_TOKEN=
# GOOGLE_ANALYTICS_CONNECTOR_TEST_PROPERTY_ID=

# ── Connecteur Meta Ads (cockpit — OAuth) ─────────────────────────────────────
# Meta for Developers : app Business + Marketing API + Facebook Login.
# Redirect URI : https://<domaine>/api/connectors/meta-ads/callback
META_ADS_CLIENT_ID=
META_ADS_CLIENT_SECRET=
META_ADS_REDIRECT_URI=
# META_ADS_CONNECTOR_FALLBACK=1   # snapshots vides (dev sans quota API)
# META_ADS_CONNECTOR_TEST_ACCESS_TOKEN=
# META_ADS_CONNECTOR_TEST_AD_ACCOUNT_ID=

# ── Connecteur TikTok Ads (cockpit — OAuth) ─────────────────────────────────
# TikTok for Business : app avec Marketing API v1.3.
# Redirect URI : https://<domaine>/api/connectors/tiktok-ads/callback
TIKTOK_ADS_APP_ID=
TIKTOK_ADS_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=
# TIKTOK_ADS_CONNECTOR_FALLBACK=1   # snapshots vides (dev sans quota API)
# TIKTOK_ADS_CONNECTOR_TEST_ACCESS_TOKEN=
# TIKTOK_ADS_CONNECTOR_TEST_ADVERTISER_ID=

# ── Connecteur LinkedIn Ads (cockpit — OAuth Campaign Manager) ────────────────
# App LinkedIn Developer avec produit Advertising API activé.
# Tier Development : whitelist des comptes dans Products → View Ad Accounts.
LINKEDIN_ADS_CLIENT_ID=
LINKEDIN_ADS_CLIENT_SECRET=
LINKEDIN_ADS_REDIRECT_URI=
# LINKEDIN_ADS_API_VERSION=202605
# LINKEDIN_ADS_CONNECTOR_FALLBACK=1   # snapshots vides (dev sans compte whitelisté)
# LINKEDIN_ADS_CONNECTOR_TEST_ACCESS_TOKEN=
# LINKEDIN_ADS_CONNECTOR_TEST_AD_ACCOUNT_ID=

# ── Connecteur Microsoft Ads (cockpit — OAuth Microsoft + Google) ─────────────
# 1. Azure Portal : app registration, permission déléguée msads.manage (Microsoft Advertising API)
# 2. Google Cloud Console : OAuth client web (comptes Google liés à Microsoft Ads)
# 3. Developer token : https://learn.microsoft.com/en-us/advertising/guides/get-started
MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_REDIRECT_URI=
MICROSOFT_ADS_GOOGLE_CLIENT_ID=
MICROSOFT_ADS_GOOGLE_CLIENT_SECRET=
MICROSOFT_ADS_DEVELOPER_TOKEN=
# MICROSOFT_ADS_TENANT=common
# MICROSOFT_ADS_USE_SANDBOX=0
# MICROSOFT_ADS_CONNECTOR_FALLBACK=1   # snapshots vides (dev sans developer token approuvé)
# MICROSOFT_ADS_CONNECTOR_TEST_ACCESS_TOKEN=
# MICROSOFT_ADS_CONNECTOR_TEST_CUSTOMER_ID=
# MICROSOFT_ADS_CONNECTOR_TEST_ACCOUNT_ID=

# ── Connecteur Plausible (cockpit — clé Stats API utilisateur) ────────────────
# Plan Business Plausible requis. Pas de secret plateforme.
# PLAUSIBLE_API_BASE=https://plausible.io   # optionnel (self-hosted)
# PLAUSIBLE_CONNECTOR_TEST_API_KEY=
# PLAUSIBLE_CONNECTOR_TEST_SITE_ID=
# PLAUSIBLE_CONNECTOR_TEST_SIGNUP_GOAL=

# Fathom connector — tests manuels optionnels (pas d'appels live en CI par défaut)
# FATHOM_CONNECTOR_TEST_API_KEY=
# FATHOM_CONNECTOR_TEST_SITE_ID=
# FATHOM_CONNECTOR_TEST_SIGNUP_EVENT_ID=

# ── Connecteur PostHog (cockpit — Personal API Key utilisateur) ───────────────
# 1. PostHog → Settings → Personal API Keys → scopes query:read, project:read, event_definition:read
# 2. Project ID dans Settings → Project
# POSTHOG_APP_HOST=https://eu.posthog.com   # optionnel (défaut us.posthog.com)
# POSTHOG_CONNECTOR_TEST_PERSONAL_API_KEY=
# POSTHOG_CONNECTOR_TEST_PROJECT_ID=
# POSTHOG_CONNECTOR_TEST_SIGNUP_EVENT=
# POSTHOG_CONNECTOR_TEST_ACTIVATION_EVENT=

# ── Connecteur Mixpanel (cockpit — Service Account utilisateur) ───────────────
# 1. Mixpanel → Organization Settings → Service Accounts (rôle Analyst+ sur le projet)
# 2. Project ID dans l’URL mixpanel.com/project/{id}/…
# 3. Région : us | eu | in
# MIXPANEL_CONNECTOR_FALLBACK=1   # dev : sync sans appels API
# MIXPANEL_CONNECTOR_TEST_USERNAME=
# MIXPANEL_CONNECTOR_TEST_SECRET=
# MIXPANEL_CONNECTOR_TEST_PROJECT_ID=
# MIXPANEL_CONNECTOR_TEST_REGION=us

# Lemon Squeezy connector — tests manuels (optionnel, hors CI)
# LEMON_SQUEEZY_CONNECTOR_TEST_API_KEY=
# LEMON_SQUEEZY_CONNECTOR_TEST_STORE_ID=

# ── Connecteur Paddle (cockpit — clé API utilisateur) ─────────────────────────
# Pas de secret plateforme. Clé sandbox ou live avec metrics.read, subscription.read, transaction.read.
# PADDLE_CONNECTOR_TEST_API_KEY=pdl_sdbx_apikey_...

# ── Connecteur Freemius (cockpit — Bearer Token produit) ─────────────────────
# Pas de secret plateforme. Token scopé à un produit depuis Settings → API Token.
# FREEMIUS_CONNECTOR_TEST_PRODUCT_ID=
# FREEMIUS_CONNECTOR_TEST_API_TOKEN=

# ── Connecteur Loops (cockpit — clé API + webhooks utilisateur) ───────────────
# Pas de secret plateforme. NEXT_PUBLIC_APP_URL requis pour l'URL webhook affichée.
# LOOPS_CONNECTOR_TEST_API_KEY=
# LOOPS_CONNECTOR_TEST_WEBHOOK_SECRET=whsec_…

# ── Connecteur Brevo (cockpit — clé API utilisateur) ─────────────────────────
# Clé restreinte : Contacts (lecture) + Campagnes email (lecture).
# Mode liste : webhook outbound Brevo → /api/connectors/brevo/webhook?projectId=…&token=…
# BREVO_CONNECTOR_TEST_API_KEY=xkeysib-…
# BREVO_CONNECTOR_TEST_LIST_ID=

# ── Connecteur Resend (cockpit — clé API utilisateur + webhook Svix) ────────────
# 1. Créer une clé Full access sur https://resend.com/api-keys
# 2. Webhook Resend → https://<domaine>/api/connectors/resend/webhook?projectId=<uuid>
#    Événements : email.clicked (obligatoire pour conversions par clics)
# 3. Copier le signing secret whsec_… dans le dialog cockpit
# RESEND_CONNECTOR_TEST_API_KEY=re_…
# RESEND_CONNECTOR_TEST_WEBHOOK_SECRET=whsec_…

# ── Connecteur Crisp (cockpit — plugin Marketplace + website_id) ──────────────
# 1. Créer un plugin sur https://marketplace.crisp.chat/
# 2. Copier identifier + key (Development ou Production)
# 3. Trusted Workspace en dev ; scopes Production : website:analytics, website:conversation:sessions
CRISP_PLUGIN_IDENTIFIER=
CRISP_PLUGIN_KEY=
# CRISP_PLUGIN_TIER=plugin
# NEXT_PUBLIC_CRISP_INSTALL_URL=https://marketplace.crisp.chat/plugins/…/install
# CRISP_CONNECTOR_FALLBACK=1
# CRISP_CONNECTOR_TEST_WEBSITE_ID=

# ── Connecteur Intercom (cockpit — OAuth workspace) ───────────────────────────
# 1. Créer une app OAuth sur https://developers.intercom.com/
# 2. Activer OAuth + redirect URI HTTPS vers /api/connectors/intercom/callback
# 3. Scopes : Read conversations, Read and list users and companies
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=
INTERCOM_REDIRECT_URI=
# INTERCOM_CONNECTOR_FALLBACK=1
# INTERCOM_CONNECTOR_TEST_ACCESS_TOKEN=

# ── Connecteur HubSpot (cockpit — CRM pipeline OAuth) ─────────────────────────
# 1. Créer une app sur https://developers.hubspot.com/
# 2. Auth tab → Redirect URL HTTPS vers /api/connectors/hubspot/callback
# 3. Scopes requis : crm.objects.deals.read
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
# HUBSPOT_REDIRECT_URI=
# HUBSPOT_CONNECTOR_FALLBACK=1
# HUBSPOT_CONNECTOR_TEST_ACCESS_TOKEN=

# ── Connecteur Pipedrive (cockpit — CRM pipeline OAuth) ───────────────────────
# 1. Créer une app sur https://developers.pipedrive.com/
# 2. Developer Hub → OAuth redirect URI HTTPS vers /api/connectors/pipedrive/callback
# 3. Scope requis : deals:read (base inclus automatiquement)
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
PIPEDRIVE_REDIRECT_URI=
# PIPEDRIVE_CONNECTOR_FALLBACK=1
# PIPEDRIVE_CONNECTOR_TEST_ACCESS_TOKEN=

# ── Connecteur Slack (cockpit — alertes OAuth bot) ───────────────────────────
# 1. Créer une app sur https://api.slack.com/apps
# 2. OAuth & Permissions → Bot scopes : chat:write, channels:read, groups:read, chat:write.public
# 3. Redirect URI HTTPS vers /api/connectors/slack/callback (ou NEXT_PUBLIC_APP_URL auto)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=
# SLACK_CONNECTOR_TEST_BOT_TOKEN=
# SLACK_CONNECTOR_TEST_CHANNEL_ID=

# ── Connecteur Zendesk (cockpit — Global OAuth + subdomain) ─────────────────
# 1. Créer un client OAuth local zdg-* sur un compte d3v-* (compte dev Zendesk)
# 2. Soumettre une demande Global OAuth sur le Zendesk Marketplace portal
# 3. Redirect URI HTTPS vers /api/connectors/zendesk/callback
# 4. Scope read (GET tickets, search, satisfaction_ratings, account)
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=
ZENDESK_REDIRECT_URI=
# ZENDESK_CONNECTOR_FALLBACK=1
# ZENDESK_CONNECTOR_TEST_SUBDOMAIN=
# ZENDESK_CONNECTOR_TEST_ACCESS_TOKEN=

# ── Connecteur Qonto (cockpit — trésorerie / runway) ─────────────────────────
# 1. Créer une app OAuth sur le Qonto Developer Portal
# 2. Activer les scopes organization.read et offline_access
# 3. Redirect URI HTTPS vers /api/connectors/qonto/callback
QONTO_CLIENT_ID=
QONTO_CLIENT_SECRET=
QONTO_REDIRECT_URI=
# Sandbox (optionnel) :
# QONTO_API_BASE=https://thirdparty-sandbox.staging.qonto.co/v2
# QONTO_OAUTH_AUTHORIZE_URL=https://oauth-sandbox.staging.qonto.co/oauth2/auth
# QONTO_OAUTH_TOKEN_URL=https://oauth-sandbox.staging.qonto.co/oauth2/token
# QONTO_STAGING_TOKEN=
# QONTO_CONNECTOR_FALLBACK=1
# QONTO_CONNECTOR_TEST_ACCESS_TOKEN=

# ── Pennylane (compta FR — stream accounting) ────────────────────────────────
# Chemin principal : token API entreprise (Paramètres > Connectivité > Développeurs).
# Permission requise : Balance générale (scope trial_balance:readonly), lecture seule.
# OAuth plateforme (optionnel — app enregistrée auprès de Pennylane Partenariats) :
# PENNYLANE_CLIENT_ID=
# PENNYLANE_CLIENT_SECRET=
# PENNYLANE_REDIRECT_URI=https://votre-domaine.com/api/connectors/pennylane/callback
# PENNYLANE_API_BASE=https://app.pennylane.com/api/external/v2
# PENNYLANE_CONNECTOR_FALLBACK=1
# PENNYLANE_CONNECTOR_TEST_TOKEN=

# ── Abby (compta micro-entreprise FR) ───────────────────────────────────────
# Clé API utilisateur : app.abby.fr → Paramètres → Intégrations
# ABBY_API_BASE=https://api.app-abby.com
# ABBY_CONNECTOR_FALLBACK=1
# ABBY_CONNECTOR_TEST_API_KEY=

# ── Better Stack (Uptime monitoring) ───────────────────────────────────────
# Token utilisateur : Better Stack → API tokens → Uptime API tokens (ou Global API token)
# BETTER_STACK_API_BASE=https://uptime.betterstack.com
# BETTER_STACK_CONNECTOR_TEST_API_TOKEN=
# BETTER_STACK_CONNECTOR_TEST_MONITOR_ID=

# ── Chiffrement credentials connecteurs (serveur uniquement) ─────────────────
# Clé secrète min. 16 caractères — jamais exposée au client.
# Requis aussi en CI pour le cron sync connecteurs (.github/workflows/connector-sync.yml).
CREDENTIALS_ENCRYPTION_KEY=
